generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoIncidente {
  CONFLICTO
  AGRESION_FISICA
  AGRESION_VERBAL
  ACOSO
  DANO_MATERIAL
}

enum NivelGravedad {
  LEVE
  MODERADO
  GRAVE
  MUY_GRAVE
}

enum EstadoCaso {
  ABIERTO
  EN_SEGUIMIENTO
  RESUELTO
  CERRADO
  DERIVADO
}

enum RolSistema {
  ADMINISTRADOR
  ENCARGADO_CONVIVENCIA
  DOCENTE
  INSPECTOR
  ORIENTADOR
  EQUIPO_DIRECTIVO
}

enum RolInvolucrado {
  AFECTADO
  RESPONSABLE
  TESTIGO
  INTERVINIENTE
}

enum TipoAccion {
  CITACION
  DERIVACION_ORIENTACION
  ENTREVISTA
  DERIVACION_PSICOLOGO
}

model Estudiante {
  id           Int           @id @default(autoincrement())
  rut          String        @unique
  nombres      String
  apellidos    String
  curso        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  involucrados Involucrado[]
}

model FuncionarioInstitucional {
  id                       Int           @id @default(autoincrement())
  rut                      String        @unique
  nombres                  String
  apellidos                String
  cargo                    RolSistema
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  usuario                  Usuario?
  incidentesRegistrados    Incidente[]
  intervencionesRealizadas Involucrado[] @relation("IntervinienteFuncionario")
}

model Usuario {
  id            Int                      @id @default(autoincrement())
  email         String                   @unique
  passwordHash  String
  rol           RolSistema
  activo        Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  funcionarioId Int                      @unique
  funcionario   FuncionarioInstitucional @relation(fields: [funcionarioId], references: [id])
}

model Incidente {
  id              Int                      @id @default(autoincrement())
  fecha           DateTime
  descripcion     String
  tipo            TipoIncidente
  gravedad        NivelGravedad
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  registradoPorId Int
  registradoPor   FuncionarioInstitucional @relation(fields: [registradoPorId], references: [id])
  involucrados    Involucrado[]
  casoIncidentes  CasoIncidente[]
}

model Involucrado {
  id                         Int                       @id @default(autoincrement())
  rol                        RolInvolucrado
  observacion                String?
  createdAt                  DateTime                  @default(now())
  estudianteId               Int
  estudiante                 Estudiante                @relation(fields: [estudianteId], references: [id])
  incidenteId                Int
  incidente                  Incidente                 @relation(fields: [incidenteId], references: [id])
  funcionarioIntervinienteId Int?
  funcionarioInterviniente   FuncionarioInstitucional? @relation("IntervinienteFuncionario", fields: [funcionarioIntervinienteId], references: [id])

  @@unique([estudianteId, incidenteId, rol])
}

model Caso {
  id             Int                  @id @default(autoincrement())
  titulo         String
  descripcion    String?
  estado         EstadoCaso           @default(ABIERTO)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  casoIncidentes CasoIncidente[]
  acciones       AccionIntervencion[]
}

model CasoIncidente {
  casoId      Int
  incidenteId Int
  asignadoEn  DateTime  @default(now())
  caso        Caso      @relation(fields: [casoId], references: [id])
  incidente   Incidente @relation(fields: [incidenteId], references: [id])

  @@id([casoId, incidenteId])
}

model AccionIntervencion {
  id          Int        @id @default(autoincrement())
  tipo        TipoAccion
  descripcion String?
  fecha       DateTime   @default(now())
  createdAt   DateTime   @default(now())
  casoId      Int
  caso        Caso       @relation(fields: [casoId], references: [id])
}
